      "results": [
        {
          "ruleId": "java.lang.security.audit.unsafe-deserialization",
          "level": "error",
          "message": { "text": "ObjectInputStream.readObject() called on untrusted data. Deserialization of user-controlled data can lead to Remote Code Execution." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/main/java/com/finsecure/service/TransactionService.java" },
                "region": { "startLine": 89, "startColumn": 8 }
