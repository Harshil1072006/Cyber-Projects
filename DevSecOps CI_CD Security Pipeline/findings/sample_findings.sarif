          ],
          "properties": {
            "id": "FIND-003",
            "stage": "SAST",
            "severity": "CRITICAL",
            "cwe": "CWE-502",
            "cvss_score": 9.8,
            "cvss_vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H",
            "owasp_category": "A08:2021 - Software and Data Integrity Failures",
            "compliance": {
              "pci_dss": ["6.2.4 - Injection Attacks"],
              "iso_27001": ["A.8.26 - Application Security Requirements"],
              "soc2": ["CC7.2 - System Monitoring"]
            },
            "evidence": "ObjectInputStream ois = new ObjectInputStream(request.getInputStream()); Object obj = ois.readObject();",
            "remediation": "Use a safe serialization library like Jackson/Gson for JSON. If Java serialization is required, implement ObjectInputFilter with an allowlist.",
            "remediation_effort": "Medium",
            "gate_blocking": true,
            "status": "Open"
          }
        },
        {
          "ruleId": "java.spring.security.audit.csrf-disabled",
          "level": "warning",
          "message": { "text": "CSRF protection is explicitly disabled in Spring Security configuration. Financial APIs processing transactions must enforce CSRF tokens." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/main/java/com/finsecure/config/SecurityConfig.java" },
                "region": { "startLine": 35, "startColumn": 16 }
              }
            }
          ],
          "properties": {
            "id": "FIND-004",
            "stage": "SAST",
            "severity": "HIGH",
            "cwe": "CWE-352",
            "cvss_score": 8.1,
            "cvss_vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:N",
            "owasp_category": "A01:2021 - Broken Access Control",
            "compliance": {
              "pci_dss": ["6.5.9 - CSRF Prevention"],
              "iso_27001": ["A.8.26 - Application Security Requirements"],
              "soc2": ["CC6.1 - Logical Access Controls"]
            },
            "evidence": "http.csrf().disable();",
            "remediation": "Remove .csrf().disable() and configure CsrfTokenRepository: http.csrf().csrfTokenRepository(CookieCsrfTokenRepository.withHttpOnlyFalse());",
            "remediation_effort": "Low",
            "gate_blocking": true,
            "status": "Open"
          }
        }
      ]
    },
