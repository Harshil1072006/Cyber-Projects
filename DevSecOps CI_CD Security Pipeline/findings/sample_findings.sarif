  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SonarQube",
          "version": "10.4",
          "informationUri": "https://www.sonarqube.org/",
          "rules": [
            {
              "id": "java:S3649",
              "shortDescription": { "text": "SQL Injection" },
              "helpUri": "https://rules.sonarsource.com/java/RSPEC-3649"
            },
            {
              "id": "java:S2068",
              "shortDescription": { "text": "Hardcoded Credentials" },
              "helpUri": "https://rules.sonarsource.com/java/RSPEC-2068"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "java:S3649",
          "level": "error",
          "message": { "text": "SQL query built from user-controlled input without parameterization. Use PreparedStatement with bind parameters." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/main/java/com/finsecure/controller/AccountController.java" },
                "region": { "startLine": 47, "startColumn": 12 }
              }
            }
          ],
          "properties": {
            "id": "FIND-001",
            "stage": "SAST",
            "severity": "CRITICAL",
            "cwe": "CWE-89",
            "cvss_score": 9.8,
            "cvss_vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H",
            "owasp_category": "A03:2021 - Injection",
            "compliance": {
              "pci_dss": ["6.2.4 - Injection Attacks", "6.5.1 - Injection Flaws"],
              "iso_27001": ["A.8.26 - Application Security Requirements"],
              "soc2": ["CC6.1 - Logical Access Controls"]
            },
            "evidence": "String query = \"SELECT * FROM accounts WHERE id = \" + request.getParameter(\"accountId\");",
            "remediation": "Replace string concatenation with PreparedStatement: pstmt = conn.prepareStatement(\"SELECT * FROM accounts WHERE id = ?\"); pstmt.setString(1, accountId);",
            "remediation_effort": "Low",
            "gate_blocking": true,
            "status": "Open"
          }
        },
        {
          "ruleId": "java:S2068",
          "level": "warning",
          "message": { "text": "Database password hardcoded in source code. Move to externalized configuration with encryption." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/main/java/com/finsecure/config/DatabaseConfig.java" },
                "region": { "startLine": 23, "startColumn": 5 }
              }
            }
          ],
          "properties": {
            "id": "FIND-002",
            "stage": "SAST",
            "severity": "HIGH",
            "cwe": "CWE-798",
            "cvss_score": 7.5,
            "cvss_vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N",
            "owasp_category": "A07:2021 - Identification and Authentication Failures",
            "compliance": {
              "pci_dss": ["2.1 - Default Credentials", "3.4 - Render PAN Unreadable"],
              "iso_27001": ["A.8.4 - Access to Source Code"],
              "soc2": ["CC6.1 - Logical Access Controls"]
            },
            "evidence": "private static final String DB_PASSWORD = \"FinS3cure_Pr0d!\";",
            "remediation": "Use environment variables or HashiCorp Vault: String dbPassword = System.getenv(\"DB_PASSWORD\");",
            "remediation_effort": "Low",
            "gate_blocking": true,
            "status": "Open"
          }
        }
      ]
    },
    {
      "tool": {
        "driver": {
          "name": "Semgrep",
          "version": "1.55.1",
          "informationUri": "https://semgrep.dev/",
          "rules": [
            {
              "id": "java.lang.security.audit.unsafe-deserialization",
