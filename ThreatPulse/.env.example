# Environment Variables — Copy to .env and fill in your API keys
# NEVER commit .env to version control!

# ─── Database ───
DATABASE_URL=postgresql://tip_user:tip_password@localhost:5432/threat_intel
POSTGRES_USER=tip_user
POSTGRES_PASSWORD=tip_password
POSTGRES_DB=threat_intel

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── API Keys (Free Tiers) ───
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ALIENVAULT_OTX_API_KEY=your_alienvault_otx_api_key_here
IPINFO_API_KEY=your_ipinfo_api_key_here
SHODAN_API_KEY=your_shodan_api_key_here

# ─── SIEM Configuration ───
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=threat-intel
SIEM_TYPE=elastic

# ─── Pipeline Settings ───
LOG_LEVEL=INFO
IOC_RETENTION_DAYS_IP=30
IOC_RETENTION_DAYS_DOMAIN=60
IOC_RETENTION_DAYS_URL=7
IOC_RETENTION_DAYS_HASH=365
ENRICHMENT_CACHE_TTL_HOURS=24

# ─── Grafana ───
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
